{
    "root_filename": "fitting_{year}_zgcr_msd.root",
    "qcd_proc": "GJets",
    "pt_min_scale": 250.0,
    "regions_to_fit": ["bb", "cc"],
    "do_systematics": false,
    "active_systematics": ["pileup", "JES", "JER"],
    "rho_scaling_max": -1.0,
    "samples_qq": ["Wjets", "Zjets", "Wgamma", "Zgamma", "TTGamma"],

    "observable": {
        "name": "msd",
        "branch_name": "FatJet0_msd",
        "min": 20,
        "max": 201,
        "nbins": 23
    },

    "categories": {
        "zgcr": {
            "name": "control-zgamma",
            "bins": [250, 1200],
            "bin_branch": "FatJet0_pt",
            "bin_prefix": "pt"
        }
    },

    "process_groups": {
        "zgammabb": { "components": [["Zgamma", "bb"], ["Zjets", "bb"]], "is_signal": true },
        "zgammacc": { "components": [["Zgamma", "c"], ["Zjets", "c"]], "is_signal": true },
        "wgammacs": { "components": [["Wgamma", "c"], ["Wjets", "c"]], "is_signal": false },
        "other": {
            "components": [
                ["Wgamma", "bb"],
                ["Wjets", "bb"],
                ["Zgamma", "light"],
                ["Wgamma", "light"],
                ["Zjets", "light"],
                ["Wjets", "light"],
                ["ttbar", ""]
            ],
            "is_signal": false
        }
    },

    "physics_model": {
        "model": "HiggsAnalysis.CombinedLimit.PhysicsModel:multiSignalModel",
        "maps": [
            "map=.*/zgammabb:r_bb[1,-100,100]",
            "map=.*/zgammacc:r_cc[1,-100,100]"
        ]
    }
}
