{
    "root_filename": "fitting_{year}_signal_msd.root",
    "qcd_proc": "QCD",
    "pt_min_scale": 450.0,
    "regions_to_fit": ["bb", "cc"],
    "do_BDT_regions": true,
    "rho_scaling_max": -2.1,
    "do_systematics": false,
    "do_muon_CR": true,
    "active_systematics": [
        "pileup", "JES", "JER", "UES",
        "btagSFb", "btagSFc", "btagSFlight",
        "btagSFb_correlated", "btagSFc_correlated", "btagSFlight_correlated"
    ],


    "samples_qq": ["Wjets", "Zjets", "EWKW", "EWKZ", "EWKV"],

    "observable": {
        "name": "msd",
        "branch_name": "FatJet0_msdmatched",
        "min": 40,
        "max": 201,
        "nbins": 23
    },

"categories": {
        "ggf": { "bins": [450, 1200] },
        "vbf": {
            "bins": [1000, 13000],
            "bins_pt": [450, 1200],
            "bin_branch": "VBFPair_mjj",
            "bin_prefix": "mjj"
        },
        "vh":  { "bins": [450, 1200] },
        "mucr":  { "bins": [450, 1200] }
    },

    "process_groups": {
        "ggF": { "components": [["ggF", ""]], "is_signal": true },
        "VBF": { "components": [["VBF", ""]], "is_signal": true },
        "WH":  { "components": [["WH", ""]], "is_signal": true },
        "ZH":  { "components": [["ZH", ""]], "is_signal": true },
        "ttH": { "components": [["ttH", ""]], "is_signal": false },
        "ttbar": { "components": [["ttbar", ""]], "is_signal": false },
        "singlet": { "components": [["singlet", ""]], "is_signal": false },
        "VV":    { "components": [["VV", ""]], "is_signal": false },

        "Wjets": { "components": [["Wjets", "c"], ["Wjets", "light"]], "is_signal": false },
        "EWKW":  { "components": [["EWKW", "c"], ["EWKW", "light"]], "is_signal": false },

        "Zjetsbb": { "components": [["Zjets", "bb"]], "is_signal": false },
        "Zjetsc":  { "components": [["Zjets", "c"]], "is_signal": false },
        "Zjetslight": { "components": [["Zjets", "light"]], "is_signal": false },
        "EWKZbb": { "components": [["EWKZ", "bb"]], "is_signal": false },
        "EWKZc":  { "components": [["EWKZ", "c"]], "is_signal": false },
        "EWKZlight": { "components": [["EWKZ", "light"]], "is_signal": false }
    },

    "physics_model": {
        "model": "HiggsAnalysis.CombinedLimit.PhysicsModel:multiSignalModel",
        "maps": [
            "map=.*/ggF:rggF[1,-20,20]",
            "map=.*/VBF:rVBF[1,-20,20]",
            "map=.*/WH:rVH[1,-20,20]",
            "map=.*/ZH:rVH[1,-20,20]"
        ]
    }
}
